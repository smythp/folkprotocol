---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const domains = await getCollection('domains');
  return domains.map(domain => ({
    params: { id: domain.id },
    props: { domain },
  }));
}

const { domain } = Astro.props;
const { Content } = await render(domain);
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{domain.data.title} - Folk Protocol</title>
  <style>
    body {
      font-family: system-ui, sans-serif;
      max-width: 800px;
      margin: 2rem auto;
      padding: 0 1rem;
      line-height: 1.6;
    }
    .back { margin-bottom: 1rem; }
    .back a { color: #666; text-decoration: none; }
    .meta { color: #666; font-size: 0.9rem; margin-bottom: 1rem; }
    .badge {
      display: inline-block;
      font-size: 0.75rem;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      background: #dbeafe;
      color: #1e40af;
      margin-right: 0.5rem;
    }
    h1 { margin-bottom: 0.5rem; }
    .summary { font-size: 1.1rem; color: #374151; margin-bottom: 2rem; }
  </style>
</head>
<body>
  <div class="back"><a href="/">← Folk Protocol</a></div>

  <h1>{domain.data.title}</h1>
  <p class="summary">{domain.data.summary}</p>

  <div class="meta">
    <span class="badge">{domain.data.researchDepth}</span>
    {domain.data.symptoms && domain.data.symptoms.map(s => (
      <span class="badge">{s}</span>
    ))}
  </div>

  <Content />

  {domain.data.related && domain.data.related.length > 0 && (
    <div class="related">
      <h3>Related</h3>
      <ul>
        {domain.data.related.map(r => (
          <li><a href={`/domains/${r}`}>{r}</a></li>
        ))}
      </ul>
    </div>
  )}
</body>
</html>
