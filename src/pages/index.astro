---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const domains = await getCollection('domains');
const herbs = await getCollection('herbs');
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Folk Protocol</title>
</head>
<body>
  <div class="container">
    <h1>Folk Protocol</h1>
    <p class="summary">Evidence-aware herbalism. Traditional knowledge meets modern curiosity.</p>

    <h2>Problem Domains</h2>
    <ul class="item-list">
      {domains.map(domain => (
        <li>
          <a href={`/domains/${domain.id}`} class="item-title">{domain.data.title}</a>
          {domain.data.draft && <span class="badge badge-draft">draft</span>}
          <div class="item-summary">{domain.data.summary}</div>
        </li>
      ))}
    </ul>

    <h2>Herbs</h2>
    <ul class="item-list">
      {herbs.map(herb => (
        <li>
          <a href={`/herbs/${herb.id}`} class="item-title">{herb.data.name}</a>
          {herb.data.latinName && <span class="item-latin"> {herb.data.latinName}</span>}
          {herb.data.draft && <span class="badge badge-draft">draft</span>}
          <div class="item-summary">{herb.data.summary}</div>
        </li>
      ))}
    </ul>
  </div>
</body>
</html>
