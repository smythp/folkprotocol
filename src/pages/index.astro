---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const protocols = await getCollection('protocols');
const materia = await getCollection('materia');
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Folk Protocol</title>
</head>
<body>
  <div class="container">
    <h1>Folk Protocol</h1>
    <p class="summary">Evidence-aware herbalism. Traditional knowledge meets modern curiosity.</p>

    <h2>Protocols</h2>
    <ul class="item-list">
      {protocols.map(protocol => (
        <li>
          <a href={`/protocols/${protocol.id}`} class="item-title">{protocol.data.title}</a>
          {protocol.data.draft && <span class="badge badge-draft">draft</span>}
          <div class="item-summary">{protocol.data.summary}</div>
        </li>
      ))}
    </ul>

    <h2>Materia</h2>
    <ul class="item-list">
      {materia.map(item => (
        <li>
          <a href={`/materia/${item.id}`} class="item-title">{item.data.name}</a>
          {item.data.latinName && <span class="item-latin"> {item.data.latinName}</span>}
          {item.data.draft && <span class="badge badge-draft">draft</span>}
          <div class="item-summary">{item.data.summary}</div>
        </li>
      ))}
    </ul>
  </div>
</body>
</html>
