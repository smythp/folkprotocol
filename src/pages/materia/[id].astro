---
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const herbs = await getCollection('herbs');
  return herbs.map(herb => ({
    params: { id: herb.id },
    props: { herb },
  }));
}

const { herb } = Astro.props;
const { Content } = await render(herb);

const evidenceClasses: Record<string, string> = {
  strong: 'badge-evidence-strong',
  moderate: 'badge-evidence-moderate',
  preliminary: 'badge-evidence-preliminary',
  traditional: 'badge-evidence-traditional',
  weak: 'badge-evidence-weak',
};
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{herb.data.name} – Folk Protocol</title>
</head>
<body>
  <div class="container">
    <a href="/" class="back-link">← Folk Protocol</a>

    <h1>{herb.data.name}</h1>
    {herb.data.latinName && <p class="meta"><em>{herb.data.latinName}</em></p>}
    <p class="summary">{herb.data.summary}</p>

    {herb.data.evidenceByDomain && (
      <div class="meta">
        {Object.entries(herb.data.evidenceByDomain).map(([domain, level]) => (
          <span class={`badge ${evidenceClasses[level]}`}>
            {domain}: {level}
          </span>
        ))}
      </div>
    )}

    {herb.data.traditionalUse && (
      <section>
        <h2>Traditional Use</h2>
        {herb.data.traditionalUse.traditions && (
          <p><strong>Traditions:</strong> {herb.data.traditionalUse.traditions.join(', ')}</p>
        )}
        {herb.data.traditionalUse.convergent && <p><strong>Multiple traditions agree on use.</strong></p>}
        {herb.data.traditionalUse.notes && <p>{herb.data.traditionalUse.notes}</p>}
      </section>
    )}

    {herb.data.preparations && herb.data.preparations.length > 0 && (
      <section>
        <h2>Preparations</h2>
        {herb.data.preparations.map(prep => (
          <div class="prep-card">
            <span class="prep-method">{prep.method}</span>
            {prep.dosing && <span class="prep-dosing"> — {prep.dosing}</span>}
            {prep.notes && <p>{prep.notes}</p>}
          </div>
        ))}
      </section>
    )}

    <Content />

    {herb.data.safety && (
      <section>
        <h2>Safety</h2>
        <div class="callout-warning">
          {herb.data.safety.generally && <p><strong>Generally considered:</strong> {herb.data.safety.generally}</p>}
          {herb.data.safety.contraindications && herb.data.safety.contraindications.length > 0 && (
            <p><strong>Contraindications:</strong> {herb.data.safety.contraindications.join(', ')}</p>
          )}
          {herb.data.safety.notes && <p>{herb.data.safety.notes}</p>}
        </div>
      </section>
    )}

    {herb.data.sources && herb.data.sources.length > 0 && (
      <section>
        <h2>Sources</h2>
        <ul>
          {herb.data.sources.map(source => (
            <li>
              {source.url ? <a href={source.url}>{source.title}</a> : source.title}
              {source.type && <span class="badge">{source.type}</span>}
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</body>
</html>
