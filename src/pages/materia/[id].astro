---
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const materia = await getCollection('materia');
  return materia.map(item => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const evidenceClasses: Record<string, string> = {
  strong: 'badge-evidence-strong',
  moderate: 'badge-evidence-moderate',
  preliminary: 'badge-evidence-preliminary',
  traditional: 'badge-evidence-traditional',
  weak: 'badge-evidence-weak',
};
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{item.data.name} – Folk Protocol</title>
</head>
<body>
  <div class="container">
    <a href="/" class="back-link">← Folk Protocol</a>

    <h1>{item.data.name}</h1>
    {item.data.latinName && <p class="meta"><em>{item.data.latinName}</em></p>}
    {item.data.commonNames && item.data.commonNames.length > 0 && (
      <p class="meta">Also known as: {item.data.commonNames.join(', ')}</p>
    )}
    <p class="summary">{item.data.summary}</p>

    {item.data.uses && item.data.uses.length > 0 && (
      <div class="meta">
        <strong>Used for:</strong> {item.data.uses.map(use => (
          <span class="badge">{use}</span>
        ))}
      </div>
    )}

    {item.data.traditional && (
      <section>
        <h2>Traditional Use</h2>
        {item.data.traditional.traditions && (
          <p><strong>Traditions:</strong> {item.data.traditional.traditions.join(', ')}</p>
        )}
        {item.data.traditional.convergent && <p><strong>Multiple traditions agree on use.</strong></p>}
        {item.data.traditional.attributions && item.data.traditional.attributions.length > 0 && (
          <div>
            <h3>Historical Attributions</h3>
            {item.data.traditional.attributions.map(attr => (
              <blockquote>
                <p>{attr.text}</p>
                <footer>
                  — {attr.source}
                  {attr.year && ` (${attr.year})`}
                  {attr.link && <> • <a href={attr.link}>source</a></>}
                </footer>
              </blockquote>
            ))}
          </div>
        )}
      </section>
    )}

    {item.data.evidence && (
      <section>
        <h2>Evidence</h2>
        {item.data.evidence.summary && <p>{item.data.evidence.summary}</p>}
        {(item.data.evidence.trialCount || item.data.evidence.participantCount) && (
          <p class="meta">
            {item.data.evidence.trialCount && <span>{item.data.evidence.trialCount} trials</span>}
            {item.data.evidence.participantCount && <span> • {item.data.evidence.participantCount} participants</span>}
          </p>
        )}
        {item.data.evidence.keyStudies && item.data.evidence.keyStudies.length > 0 && (
          <div>
            <h3>Key Studies</h3>
            <ul>
              {item.data.evidence.keyStudies.map(study => (
                <li>
                  {study.link ? <a href={study.link}>{study.title}</a> : study.title}
                  {study.year && ` (${study.year})`}
                  {study.finding && <p>{study.finding}</p>}
                </li>
              ))}
            </ul>
          </div>
        )}
      </section>
    )}

    {item.data.preparations && item.data.preparations.length > 0 && (
      <section>
        <h2>Preparations</h2>
        {item.data.preparations.map(prep => (
          <div class="prep-card">
            <span class="prep-method">{prep.method}</span>
            {prep.dosing && <span class="prep-dosing"> — {prep.dosing}</span>}
            {prep.taste && <p><em>Taste:</em> {prep.taste}</p>}
            {prep.notes && <p>{prep.notes}</p>}
          </div>
        ))}
      </section>
    )}

    <Content />

    {item.data.trying && (
      <section>
        <h2>Trying It</h2>
        {item.data.trying.duration && <p><strong>Duration:</strong> {item.data.trying.duration}</p>}
        {item.data.trying.whatToNotice && item.data.trying.whatToNotice.length > 0 && (
          <div>
            <p><strong>What to notice:</strong></p>
            <ul>
              {item.data.trying.whatToNotice.map(notice => (
                <li>{notice}</li>
              ))}
            </ul>
          </div>
        )}
        {item.data.trying.notes && <p>{item.data.trying.notes}</p>}
      </section>
    )}

    {item.data.combinedWith && item.data.combinedWith.length > 0 && (
      <section>
        <h2>Combinations</h2>
        <ul>
          {item.data.combinedWith.map(combo => (
            <li>
              <strong>{combo.herb}</strong>
              {combo.why && <span> — {combo.why}</span>}
            </li>
          ))}
        </ul>
      </section>
    )}

    {item.data.safety && (
      <section>
        <h2>Safety</h2>
        <div class="callout-warning">
          {item.data.safety.generally && <p><strong>Generally considered:</strong> {item.data.safety.generally}</p>}
          {item.data.safety.contraindications && item.data.safety.contraindications.length > 0 && (
            <div>
              <p><strong>Contraindications:</strong></p>
              <ul>
                {item.data.safety.contraindications.map(ci => (
                  <li>{ci}</li>
                ))}
              </ul>
            </div>
          )}
          {item.data.safety.pregnancyNursing && <p><strong>Pregnancy/Nursing:</strong> {item.data.safety.pregnancyNursing}</p>}
          {item.data.safety.notes && <p>{item.data.safety.notes}</p>}
        </div>
      </section>
    )}

    {item.data.sources && item.data.sources.length > 0 && (
      <section>
        <h2>Sources</h2>
        <ul>
          {item.data.sources.map(source => (
            <li>
              {source.link ? <a href={source.link}>{source.title}</a> : source.title}
              {source.type && <span class="badge">{source.type}</span>}
              {source.year && ` (${source.year})`}
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</body>
</html>
